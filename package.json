{
  "name": "book-to-video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,worker,frontend -c blue,yellow,green \"tsx watch server/index.ts\" \"tsx watch worker/index.ts\" \"vite\"",
    "dev:infra": "docker compose up postgres redis",
    "dev:docker": "docker compose up",
    "dev:build": "docker compose up --build",
    "dev:down": "docker compose down",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "worker": "tsx worker/index.ts",
    "server": "tsx server/index.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:fixtures": "tsx tests/fixtures/create.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.68",
    "@anthropic-ai/sdk": "^0.101.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.197",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tiktoken": "^1.0.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "typescript-eslint": "^8.60.1",
    "vite": "^6",
    "vitest": "^4.1.8"
  }
}
